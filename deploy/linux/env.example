# predigy environment for Linux systemd deployment.
#
# Copy to ~/.config/predigy/env and edit. systemd services load this
# via EnvironmentFile=, so values must be plain VAR=value (no `export`,
# no shell expansion). The wrapper scripts under deploy/scripts/ still
# read the same variable names, so logic remains identical to macOS.

# -- Required Kalshi credentials --
KALSHI_KEY_ID=REPLACE_ME_WITH_UUID
KALSHI_PEM=/home/dan/.config/predigy/kalshi.pem

# -- Required curator credential --
ANTHROPIC_API_KEY=REPLACE_ME

# -- Required NOAA politeness header (wx-stat-curator, NWS clients) --
PREDIGY_NWS_USER_AGENT=predigy/1.0 (dan@pourhadi.com)

# -- Engine mode --
# Start with "shadow" during cutover. Flip to "live" only after the
# shadow run looks clean.
PREDIGY_ENGINE_MODE=shadow
PREDIGY_ENGINE_AUTO_MIGRATE=true

# -- Risk caps (cents) --
# Per-strategy cap raised 8000 → 16000 on 2026-05-14 after pausing
# book-maker and reallocating its capital to internal-arb (see strategy
# gating section below). Global cap unchanged.
PREDIGY_MAX_NOTIONAL_CENTS=16000
PREDIGY_MAX_GLOBAL_NOTIONAL_CENTS=20000
PREDIGY_MAX_DAILY_LOSS_CENTS=2000
PREDIGY_MAX_CONTRACTS_PER_SIDE=100
PREDIGY_MAX_IN_FLIGHT=200

# -- XDG-style paths on Linux --
PREDIGY_HOME=/home/dan/code/predigy
PREDIGY_LOG_DIR=/home/dan/.local/state/predigy/logs
PREDIGY_KILL_SWITCH_FILE=/home/dan/.config/predigy/kill-switch.flag

# -- Strategy gating (omit a var to skip registering its strategy) --
PREDIGY_CROSS_ARB_PAIR_FILE=/home/dan/.config/predigy/cross-arb-pairs.txt
PREDIGY_IMPLICATION_ARB_CONFIG=/home/dan/.config/predigy/implication-arb-config.json
PREDIGY_INTERNAL_ARB_CONFIG=/home/dan/.config/predigy/internal-arb-config.json
# 2026-05-14: paused — -$1.16 net over 14 trades post-pnl-sign-fix;
# asymmetric loss profile persists (avg loss 2-3x avg win) suggesting
# adverse-selection issues the fix didn't address. Capital reallocated
# to internal-arb via the raised per-strategy cap above. Re-enable by
# uncommenting once book-maker has a thesis-validated config change.
#PREDIGY_BOOK_MAKER_CONFIG=/home/dan/.config/predigy/book-maker-config.json

# -- Postgres --
DATABASE_URL=postgresql:///predigy

# -- Backups --
# Default on SD card. The Pi's USB drive is exfat (no Unix ACLs)
# and owned by a different uid, so dan-as-systemd can't write
# there without remounting. 30 days of dumps at this DB size
# fit comfortably on SD. Layer rclone-to-cloud on top if you
# want offsite redundancy.
PREDIGY_BACKUP_DIR=/home/dan/.local/state/predigy/backups
PREDIGY_BACKUP_RETAIN_DAYS=30

# -- Dashboard --
# Bind to LAN so the operator can hit http://nas.local:8080. Set to
# 127.0.0.1:8080 if you want SSH-tunnel-only access.
PREDIGY_DASH_BIND=0.0.0.0:8080
