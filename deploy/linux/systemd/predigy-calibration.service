[Unit]
Description=predigy calibration (settlement sync + venue-flat reconcile + reports)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/code/predigy
EnvironmentFile=%h/.config/predigy/env
ExecStart=%h/code/predigy/deploy/scripts/predigy-calibration-run.sh
StandardOutput=append:%h/.local/state/predigy/logs/calibration.stdout.log
StandardError=append:%h/.local/state/predigy/logs/calibration.stderr.log
