<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- predigy-paper-trader: shadow-execute stat-curator rules
         against live Kalshi prices, log to paper_trades, reconcile
         on settlement. NO ORDERS submitted. Evidence layer that
         gates the `stat` strategy's re-enable.

         Cadence: every 5 minutes. The curator runs hourly so worst
         case we capture entry prices ~5 min after a fresh rule
         lands. Same-day-settling markets settle within hours, so
         this loop generates evidence on a same-day cycle. -->
    <key>Label</key>
    <string>com.predigy.paper-trader</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>exec /Users/dan/code/predigy/deploy/scripts/predigy-paper-trader-run.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/dan/Library/Logs/predigy/paper-trader.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/dan/Library/Logs/predigy/paper-trader.stderr.log</string>
</dict>
</plist>
